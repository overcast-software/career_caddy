# Career Caddy — environment template
# Copy to .env and fill in values: cp .env.example .env
# .env is gitignored and loaded automatically by docker compose.

# ── Database ──────────────────────────────────────────────────────────────
DB_NAME=job_hunting
DB_USER=postgres
DB_PASSWORD=postgres

# ── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-secure-random-value
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200

# ── JWT (optional overrides) ──────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email (SMTP) ─────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@careercaddy.online
FRONTEND_URL=http://localhost:4200

# ── Feature flags ─────────────────────────────────────────────────────────
SCRAPING_ENABLED=False
ALLOW_BOOTSTRAP_SUPERUSER=False
BOOTSTRAP_TOKEN=

# ── Browser / Camoufox ────────────────────────────────────────────────────
# Set to true to include the Camoufox Firefox binary (~700 MB) in the ai image.
# Required when running the browser-mcp service (--profile browser).
# Set to false for production or any environment that only uses the core stack.
INSTALL_CAMOUFOX=true

# Enable MCP browser agent for job scraping (requires --profile browser / make up-ai)
USE_MCP_BROWSER_AGENT=False
# SSE endpoint for the browser-mcp service (docker-compose overrides this to http://browser-mcp:3004/sse)
BROWSER_MCP_SSE_URL=http://0.0.0.0:3004/sse

# Set to false to run browser in headed mode (useful for local debugging with hold poller)
BROWSER_HEADLESS=true

# Hold poller poll interval in seconds (default: 30)
# HOLD_POLL_INTERVAL=30

# ── AI / LLM ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_API_BASE=http://host.docker.internal:11434

# Per-agent model overrides (provider:model format)
# Every role has an env var override — set to swap that agent's model.
# Leave unset → falls back to CADDY_DEFAULT_MODEL → hardcoded default.
# Full role table visible in-app at /admin/ai-models.
CADDY_DEFAULT_MODEL=openai:gpt-4o-mini
# --- ai/ agents (resolved via agent_factory.get_model()) ---
# CADDY_MODEL=openai:gpt-4o-mini
# CHAT_MODEL=anthropic:claude-haiku-4-5
# JOB_EXTRACTOR_MODEL=anthropic:claude-haiku-4-5
# BROWSER_SCRAPER_MODEL=openai:gpt-4o-mini
# --- Django-side parsers ---
# RESUME_INGEST_MODEL=anthropic:claude-sonnet-4-6
#   Default (when unset): Anthropic > OpenAI > Ollama depending on which API key is set.
# JOB_PARSER_MODEL=openai:gpt-4o
# HINT_GENERATOR_MODEL=openai:gpt-4o-mini

# ── Career Caddy AI layer ─────────────────────────────────────────────────
# Long-lived API key for the AI agent to authenticate against the Django API
CC_API_TOKEN=

# MCP server bind address (used by caddy-mcp / agents-gw / browser-mcp services)
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=3002

# Path to notmuch-indexed maildir on the host (bind-mounted into ai containers)
# Example: NOTMUCH_MAILDIR=/home/user/Mail
NOTMUCH_MAILDIR=

# Logfire observability (optional)
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=development

# ── Deployment ────────────────────────────────────────────────────────────
# Docker image tag to deploy (default: latest)
IMAGE_TAG=latest

# Tailscale IP for remote PostgreSQL access (optional, production only)
TAILSCALE_IP=
