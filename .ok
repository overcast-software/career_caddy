# ── Dev stack ──────────────────────────────────────────────────────────────
make up
make down
make logs
make build

# ── Shells / DB ────────────────────────────────────────────────────────────
make shell-api
make shell-db
make migrate

# ── CI via Dagger (no secrets needed) ─────────────────────────────────────
dagger -m ./dagger call build-api
dagger -m ./dagger call build-frontend
dagger -m ./dagger call build-ai

# ── Publish images to GHCR ────────────────────────────────────────────────
dagger -m ./dagger call publish --registry-token=env:GITHUB_TOKEN --org=overcast-software --tag=latest

# ── Deploy to VPS ─────────────────────────────────────────────────────────
dagger -m ./dagger call deploy --ssh-key=file:~/.ssh/id_ed25519 --host=192.3.252.74 --ssh-user=oldbones --app-dir=/home/oldbones/Projects/career_caddy --tag=latest

# ── AI pipeline ────────────────────────────────────────────────────────────
make pipeline
make pipeline-url URL=https://

# ── Misc ───────────────────────────────────────────────────────────────────
make help
curl -s http://localhost:8000/api/v1/healthcheck/ | python3 -m json.tool
